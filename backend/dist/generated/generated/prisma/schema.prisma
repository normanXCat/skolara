// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

/// Rôle utilisateur dans le système Skolara
enum Role {
  ADMIN
  ENSEIGNANT
  ELEVE
  PARENT
}

/// Statut d'une pré-inscription
enum Status {
  PENDING
  IN_REVIEW
  ACCEPTED
  REJECTED
}

/// Modèle utilisateur principal
model User {
  id                     Int               @id @default(autoincrement())
  firstName              String
  name                   String
  email                  String            @unique
  passwordHash           String
  role                   Role              @default(ELEVE)
  active                 Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  refreshTokens          RefreshToken[]
  processedRegistrations PreRegistration[]

  @@map("users")
}

/// Tokens de rafraîchissement pour la rotation sécurisée
model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

/// Modèle représentant une demande de pré-inscription
model PreRegistration {
  id               Int      @id @default(autoincrement())
  childFirstName   String
  childLastName    String
  childDateOfBirth DateTime
  gender           String // "M" | "F"
  childEmail       String?
  previousSchool   String?
  desiredGrade     String

  parentFirstName String
  parentFullName  String
  parentEmail     String
  parentPhone     String
  parentAddress   String?

  fileNumber      String   @unique
  receiptNumber   String?  @unique
  receiptImageUrl String?
  documentUrls    String[]

  status          Status    @default(PENDING)
  adminComment    String?
  processedBy     Int?
  processedByUser User?     @relation(fields: [processedBy], references: [id])
  processedAt     DateTime?
  studentId       Int? // FK → Student (après acceptation)

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Grade {
  id    Int    @id @default(autoincrement())
  value String @unique
  label String
}
