// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Statut d'une pré-inscription
enum Status {
  PENDING
  IN_REVIEW
  ACCEPTED
  REJECTED
}

/// Modèle représentant une demande de pré-inscription
model PreRegistration {
  id               Int      @id @default(autoincrement())
  childFirstName   String
  childLastName    String
  childDateOfBirth DateTime
  gender           String // "M" | "F"
  childEmail       String?
  previousSchool   String?
  desiredGrade     String
  targetSchoolYear String

  parentFirstName String
  parentFullName  String
  parentEmail     String
  parentPhone     String
  parentAddress   String?

  fileNumber      String   @unique
  receiptNumber   String?  @unique
  receiptImageUrl String?
  documentUrls    String[]

  status       Status    @default(PENDING)
  adminComment String?
  processedBy  Int? // FK → User
  processedAt  DateTime?
  studentId    Int? // FK → Student (après acceptation)

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
