{
    "name": "skolara-backend",
    "version": "1.0.0",
    "description": "API REST Skolara",
    "main": "dist/server.js",
    "scripts": {
        "dev": "nodemon --exec ts-node src/server.ts",
        "build": "npx prisma generate && tsc -p tsconfig.build.json && cp -r src/generated dist/generated",
        "start": "npx prisma migrate deploy &&node dist/server.js",
        "postinstall": "npx prisma generate",
        "test": "jest --forceExit --detectOpenHandles",
        "test:watch": "jest --watch --forceExit --detectOpenHandles",
        "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio",
        "seed": "npx ts-node prisma/seed.ts"
    },
    "prisma": {
        "seed": "npx ts-node prisma/seed.ts"
    },
    "keywords": [
        "skolara",
        "api"
    ],
    "author": "Norman",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "@prisma/adapter-pg": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "multer": "^2.1.1",
        "pg": "^8.20.0",
        "prisma": "^7.7.0",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.6",
        "@types/express": "^5.0.6",
        "@types/cors": "^2.8.19",
        "@types/multer": "^2.1.0",
        "@types/swagger-ui-express": "^4.1.8"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/supertest": "^7.2.0",
        "@types/node": "^22.0.0",
        "jest": "^30.3.0",
        "nodemon": "^3.1.14",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.0"
    }
}
